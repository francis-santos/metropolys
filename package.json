{
  "name": "metropolys-monorepo",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "build": "npm run build:web && npm run build:api",
    "test:e2e": "node apps/api/test/e2e-simulation.js",
    "test:playwright": "npx playwright test",
    "test:playwright:ui": "npx playwright test --ui",
    "agent:infra": "node .agent/skills/board-agents/scripts/agents/01-infra-agent.js",
    "agent:data-persistence": "node .agent/skills/board-agents/scripts/agents/02-data-persistence-agent.js",
    "agent:game-engine": "node .agent/skills/board-agents/scripts/agents/03-game-engine-agent.js",
    "agent:rules-engine": "node .agent/skills/board-agents/scripts/agents/04-rules-engine-agent.js",
    "agent:turn-manager": "node .agent/skills/board-agents/scripts/agents/05-turn-manager-agent.js",
    "agent:physics": "node .agent/skills/board-agents/scripts/agents/06-physics-agent.js",
    "agent:event-dispatcher": "node .agent/skills/board-agents/scripts/agents/07-event-dispatcher-agent.js",
    "agent:ai-opponent": "node .agent/skills/board-agents/scripts/agents/08-ai-opponent-agent.js",
    "agent:balancing": "node .agent/skills/board-agents/scripts/agents/09-balancing-agent.js",
    "agent:analytics": "node .agent/skills/board-agents/scripts/agents/10-analytics-agent.js",
    "agent:board-state": "node .agent/skills/board-agents/scripts/agents/11-board-state-agent.js",
    "agent:card-asset": "node .agent/skills/board-agents/scripts/agents/12-card-asset-agent.js",
    "agent:rule-validator": "node .agent/skills/board-agents/scripts/agents/13-rule-validator-agent.js",
    "agent:ui-ux": "node .agent/skills/board-agents/scripts/agents/14-ui-ux-agent.js",
    "agent:input": "node .agent/skills/board-agents/scripts/agents/15-input-agent.js",
    "agent:notification": "node .agent/skills/board-agents/scripts/agents/16-notification-agent.js",
    "agent:player-profile": "node .agent/skills/board-agents/scripts/agents/17-player-profile-agent.js",
    "agent:matchmaking": "node .agent/skills/board-agents/scripts/agents/18-matchmaking-agent.js",
    "agent:community": "node .agent/skills/board-agents/scripts/agents/19-community-agent.js",
    "agent:human-player": "node .agent/skills/board-agents/scripts/agents/20-human-player-agent.js",
    "agent:orchestrator": "node .agent/skills/board-agents/scripts/orchestrator.js",
    "agent:all": "node .agent/skills/board-agents/scripts/board-agents.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/platform-socket.io": "^11.1.26",
    "@nestjs/websockets": "^11.1.26"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "concurrently": "^9.1.2"
  }
}
