# Port configuration
PORT=3008

# Supabase API Access Configuration (Production env)
SUPABASE_URL=https://your-production-project-id.supabase.co
SUPABASE_ANON_KEY=production-anon-key-placeholder-replace-on-deploy
SUPABASE_SERVICE_ROLE_KEY=production-service-role-key-placeholder-replace-on-deploy

# Direct PostgreSQL database connection URL for production
DATABASE_URL=postgresql://postgres:production-db-password@db.your-production-project-id.supabase.co:5432/postgres
